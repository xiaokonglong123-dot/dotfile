[{
  "height": 32,
  "output": "eDP-1",
  "modules-left": ["custom/launcher", "custom/workspaces"],
  "modules-center": ["clock", "custom/weather"],
  "modules-right": ["tray", "custom/cpu", "memory", "battery", "backlight", "bluetooth", "network", "pulseaudio", "custom/microphone", "custom/clipboard", "custom/power"],
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "gtk-layer": true,
  "spacing": 6,

  "custom/workspaces": {
    "exec": "~/.config/waybar/scripts/workspaces-niri",
    "return-type": "json",
    "interval": 1
  },

  "clock": {
    "format": "َ°ƒ­ {:%H:%M}",
    "format-alt": "َ°ƒ­ {:%Yه¹´%mوœˆ%dو—¥ %A}",
    "tooltip-format": "<big>{:%Yه¹´%mوœˆ%dو—¥}</big>\n\n{calendar}",
    "interval": 1
  },

  "memory": {
    "format": "َ°¾µ {}%",
    "interval": 30,
    "tooltip-format": "Used: {used} / Total: {total}"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "َ°پ؛ {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°‚ƒ"],
    "tooltip-format": "ç”µé‡ڈ: {capacity}%\nهٹںçژ‡: {power} W\n{timeTo}\nهپ¥ه؛·ه؛¦: {health}%"
  },

  "bluetooth": {
    "format": "َ°‚¯ {status}",
    "format-connected": "َ°‚± {num-connected} è؟‍وژ¥",
    "format-icons": {
      "enabled": "َ°‚¯",
      "disabled": "َ°¤­"
    },
    "tooltip-format": "çٹ¶و€پ: {status}",
    "on-click": "alacritty -e bluetui",
    "interval": 5
  },

  "pulseaudio": {
    "format": "َ°•¾ {volume}%",
    "format-muted": "َ°‌ں Muted",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
  },

  "backlight": {
    "device": "amdgpu_bl1",
    "format": "َ°ƒ‍ {percent}%",
    "format-icons": ["َ°›©", "َ°›ھ", "َ°›«", "َ°›¬", "َ°›­", "َ°›®", "َ°›¯", "َ°›°", "َ°›±", "َ°›²"],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "min-step": 5
  },

  "custom/clipboard": {
    "exec": "~/.config/waybar/scripts/clipboard",
    "return-type": "json",
    "interval": 5,
    "on-click": "bash ~/.config/waybar/scripts/clipboard-menu"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 6
  },

  "network": {
    "format-wifi": "{icon}  {essid}",
    "format-ethernet": "َ°ˆ€ Ethernet",
    "format-disconnected": "َ°¤­ Disconnected",
    "format-icons": ["َ°¤‰", "َ°¤ˆ", "َ°¤†", "َ°¤…", "َ°¤¨"],
    "tooltip-format": "{ifname}\nSSID: {essid}\nIP: {ipaddr}",
    "on-click": "alacritty -e impala",
    "interval": 5
  },

  "custom/launcher": {
    "format": "َ°£‡",
    "on-click": "fuzzel --show drun",
    "tooltip": false
  },

  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu",
    "return-type": "json",
    "interval": 5,
    "tooltip": true
  },

  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather",
    "return-type": "json",
    "interval": 900,
    "tooltip": true
  },

  "custom/power": {
    "format": "َ°¤ژ",
    "on-click": "~/.config/waybar/scripts/power-menu",
    "tooltip": "Power Menu"
  },

  "custom/microphone": {
    "exec": "~/.config/waybar/scripts/microphone",
    "return-type": "json",
    "interval": 5,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-click-right": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 2%-"
  }
}]
